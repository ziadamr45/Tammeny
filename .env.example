# ========================================
# قاعدة البيانات (PostgreSQL)
# ========================================
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ========================================
# الأمان والمصادقة
# ========================================
JWT_SECRET="your-super-secret-jwt-key-minimum-32-chars"
ENCRYPTION_KEY="your-32-character-encryption-key!"

# ========================================
# SMS (Twilio) — مطلوب لـ SOS و وصلت سالم
# ========================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ========================================
# Real-time (Ably) — مطلوب للمحادثة الفورية
# ========================================
ABLY_API_KEY=""

# ========================================
# مكالمات صوت/فيديو (LiveKit) — اختياري
# ========================================
LIVEKIT_URL=""
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# ========================================
# إعدادات التطبيق
# ========================================
NEXT_PUBLIC_APP_NAME="طمنّي"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
ENABLE_DEMO_USER="false"
CRON_SECRET="your-cron-secret-key"

# ========================================
# Social Media (اختياري)
# ========================================
NEXT_PUBLIC_YOUTUBE_CHANNEL=""
NEXT_PUBLIC_FACEBOOK_PAGE=""
NEXT_PUBLIC_TWITTER_HANDLE=""
NEXT_PUBLIC_INSTAGRAM_HANDLE=""
