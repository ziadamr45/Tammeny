// This is your Prisma schema file for Tamenny (طمنّي)
// PostgreSQL on Neon

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl  = env("DATABASE_URL")
}

// User model for authentication
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  gender        String?   // "male" | "female"
  phone         String?
  avatar        String?
  address       String?   // User address
  deviceToken   String?   // For push notifications
  isVerified    Boolean   @default(false)
  
  // Password reset
  passwordResetOtp     String?
  passwordResetExpiry  DateTime?
  
  // Last known location (encrypted for security)
  lastLocationData    String?   // Encrypted JSON: { lat, lng, name, timestamp, accuracy }
  lastLocationUpdated DateTime? // When the location was last updated
  
  // Settings
  stealthMode       Boolean   @default(false) // وضع الصمت
  darkMode          Boolean   @default(false) // الوضع الليلي
  batterySaver      Boolean   @default(false) // توفير البطارية
  notificationsEnabled Boolean @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions        Session[]
  sentMessages    Message[] @relation("SenderMessages")
  receivedMessages Message[] @relation("ReceiverMessages")
  contacts        Contact[]
  emergencyContacts EmergencyContact[]
  groupsCreated   Group[] @relation("GroupCreator")
  groupMemberships GroupMember[]
  safeZones       SafeZone[]
  notifications   Notification[]
  tripHistory     TripHistory[]
  arrivedSafe     ArrivedSafe[]
  sosSessions     SOSSession[]

  @@map("users")
}

// Contact model for user's contacts
model Contact {
  id          String    @id @default(cuid())
  userId      String
  name        String
  phone       String?
  email       String?
  relation    String?   // أب, أم, أخ, أخت, زوج, زوجة, صديق, زميل
  isFavorite  Boolean   @default(false)
  isEmergencyContact Boolean @default(false)
  notifyOnArrival Boolean @default(false)
  notifyOnEmergency Boolean @default(true)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("contacts")
}

// Emergency Contact model (priority contacts for SOS)
model EmergencyContact {
  id          String    @id @default(cuid())
  userId      String
  contactId   String?   // Reference to Contact if exists
  name        String
  phone       String
  relation    String?
  priority    Int       @default(1)  // 1 = highest priority
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("emergency_contacts")
}

// Group model for group sharing
model Group {
  id          String    @id @default(cuid())
  name        String
  description String?
  createdBy   String
  createdAt   DateTime  @default(now())

  creator     User      @relation("GroupCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members     GroupMember[]

  @@index([createdBy])
  @@map("groups")
}

// Group Member model
model GroupMember {
  id          String    @id @default(cuid())
  groupId     String
  userId      String
  role        String    @default("member") // "admin" | "member"
  joinedAt    DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

// Session model for location sharing
model Session {
  id              String    @id @default(cuid())
  encryptedId     String?   @unique  // Encrypted session ID for URL (generated after creation)
  creatorId       String
  
  // Session settings
  duration        Int       // Duration in minutes (5, 60, -1 for until arrival)
  sessionType     String    // "minutes" | "until_arrival" | "manual"
  
  // Location data
  startLat        Float
  startLng        Float
  currentLat      Float?
  currentLng      Float?
  
  // Destination (optional)
  destLat         Float?
  destLng         Float?
  destName        String?
  
  // Status
  status          String    @default("active") // "active" | "completed" | "expired" | "cancelled"
  isGhostMode     Boolean   @default(false)
  isRestricted    Boolean   @default(false)  // If true, only specific users can view
  
  // Timestamps
  startedAt       DateTime  @default(now())
  expiresAt       DateTime?
  completedAt     DateTime?
  lastUpdatedAt   DateTime  @default(now())
  
  // Stats
  totalDistance   Float     @default(0)
  totalDuration   Int       @default(0)  // In seconds
  
  // Relations
  creator         User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  allowedUsers    AllowedUser[]
  locations       LocationPoint[]
  messages        Message[]
  
  @@index([creatorId])
  @@index([encryptedId])
  @@map("sessions")
}

// Allowed users for restricted sessions
model AllowedUser {
  id          String    @id @default(cuid())
  sessionId   String
  userId      String?
  email       String?   // Can invite by email
  token       String    @unique  // Unique token for this user
  hasViewed   Boolean   @default(false)
  viewedAt    DateTime?
  
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@map("allowed_users")
}

// Location points for tracking history
model LocationPoint {
  id          String    @id @default(cuid())
  sessionId   String
  lat         Float
  lng         Float
  speed       Float?    // km/h
  accuracy    Float?    // meters
  timestamp   DateTime  @default(now())
  
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
  @@map("location_points")
}

// Messages for chat
model Message {
  id          String    @id @default(cuid())
  sessionId   String
  senderId    String
  receiverId  String?
  content     String
  type        String    @default("text") // "text" | "voice" | "system"
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender      User      @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User?     @relation("ReceiverMessages", fields: [receiverId], references: [id], onDelete: SetNull)
  
  @@index([sessionId])
  @@index([senderId])
  @@map("messages")
}

// Safe Zone model for geofencing
model SafeZone {
  id              String    @id @default(cuid())
  userId          String
  name            String
  type            String    @default("other") // "home" | "work" | "school" | "family" | "shopping" | "favorite" | "other"
  latitude        Float
  longitude       Float
  radius          Int       @default(200) // in meters
  color           String    @default("safe") // "safe" | "caution"
  notifyOnEnter   Boolean   @default(true)
  notifyOnExit    Boolean   @default(true)
  
  // تنبيه خروج الأطفال
  childAlertEnabled Boolean   @default(false)
  childName       String?   // اسم الطفل
  
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("safe_zones")
}

// Notification model
model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String    // "arrived" | "nearby" | "session_expired" | "new_viewer" | "sos" | "safe_zone"
  title       String
  message     String
  data        String?   // JSON data
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("notifications")
}

// Trip History model
model TripHistory {
  id            String    @id @default(cuid())
  userId        String
  startLocation String
  endLocation   String?
  startLat      Float?
  startLng      Float?
  endLat        Float?
  endLng        Float?
  distance      Float     @default(0) // in km
  duration      Int       @default(0) // in minutes
  startTime     DateTime  @default(now())
  endTime       DateTime?
  status        String    @default("completed") // "completed" | "cancelled"
  transportMode String    @default("car") // "car" | "walking" | "bike"
  sharedWith    String?   // JSON array of names
  locationType  String    @default("other") // "home" | "work" | "school" | "family" | "shopping" | "favorite" | "other"
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trip_history")
}

// وصلت سالم - Arrived Safe Check-in
model ArrivedSafe {
  id            String    @id @default(cuid())
  userId        String
  sessionId     String?   // Related sharing session if any
  
  // Location
  latitude      Float
  longitude     Float
  locationName  String?
  
  // Notification status
  smsSent       Boolean   @default(false)
  whatsappSent  Boolean   @default(false)
  notifiedContacts String? // JSON array of contacted people
  
  // Timestamps
  createdAt     DateTime  @default(now())
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("arrived_safe")
}

// SOS Session model for emergency alerts
model SOSSession {
  id            String    @id @default(cuid())
  userId        String
  latitude      Float?
  longitude     Float?
  locationName  String?
  batteryLevel  Int?
  status        String    @default("active") // "active" | "resolved" | "expired"

  // Timestamps
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("sos_sessions")
}

// Support Ticket model for help/contact form
model SupportTicket {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  status    String   @default("open") // "open" | "in_progress" | "closed"
  createdAt DateTime @default(now())

  @@map("support_tickets")
}
